{
  "manifest_version": 3,
  "name": "Contextual Deep Work",
  "version": "1.1",
  "description": "AI-powered focus assistant",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "notifications", "alarms"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}


