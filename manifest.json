{
  "manifest_version": 3,
  "name": "Contextual Deep Work",
  "version": "1.0",
  "description": "AI-powered focus assistant",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}


